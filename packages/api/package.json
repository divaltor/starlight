{
  "name": "@starlight/api",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "type": "module",
  "scripts": {
    "build": "bun run -b tsdown",
    "lint": "oxlint --fix",
    "format": "oxfmt"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "@types/bun": "1.3.14"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@orpc/client": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@starlight/crypto": "workspace:*",
    "@starlight/utils": "workspace:*",
    "@telegram-apps/init-data-node": "^2.0.10",
    "date-fns": "^4.1.0",
    "effect": "^3.21.2",
    "grammy": "catalog:",
    "zod": "catalog:"
  }
}
