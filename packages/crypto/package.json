    "format": "oxfmt"
  },
  "devDependencies": {
    "tsdown": "catalog:"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0"
  },
  "peerDependencies": {
    "typescript": "^6"
  }
}
