{
  "name": "@starlight/utils",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "bun run db:generate && bun run -b tsdown",
    "lint": "oxlint --fix && tsc -b",
    "format": "oxfmt",
    "db:deploy": "prisma --config prisma.config.ts migrate deploy",
    "db:generate": "prisma --config prisma.config.ts generate",
    "db:migrate": "prisma --config prisma.config.ts migrate dev"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "@t3-oss/env-core": "^0.13.11",
    "dotenv": "^17.4.2",
    "ky": "catalog:",
    "sqids": "^0.3.0",
    "uuid": "^14.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "prisma": "catalog:",
    "prisma-json-types-generator": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  }
}
