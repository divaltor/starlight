{
  "name": "starlight",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@prisma/client": "^7.9.0",
      "prisma-json-types-generator": "^5.1.1",
      "@prisma/adapter-pg": "^7.9.0",
      "@prisma/instrumentation": "^7.9.0",
      "tsdown": "^0.22.13",
      "@orpc/server": "^1.14.8",
      "@orpc/client": "^1.14.8",
      "zod": "^4.4.3",
      "prisma": "^7.9.0",
      "grammy": "^1.45.1",
      "ky": "^2.0.2"
    }
  },
  "scripts": {
    "lint": "turbo lint",
    "format": "turbo format",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "prestart:server": "bun run db:generate && bun run db:deploy",
    "start:server": "turbo -F server start",
    "start:web": "turbo -F web start",
    "db:deploy": "turbo -F @starlight/utils db:deploy",
    "db:generate": "turbo -F @starlight/utils db:generate",
    "db:migrate": "turbo -F @starlight/utils db:migrate",
    "queue:classify": "turbo -F server queue:classify",
    "queue:embeddings": "turbo -F server queue:embeddings"
  },
  "dependencies": {
    "typescript": "^7.0.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@typescript/native": "npm:typescript@^7.0.2",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^7.0.2001",
    "tsdown": "^0.22.13",
    "turbo": "^2.10.5",
    "ultracite": "7.9.4"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  }
}
