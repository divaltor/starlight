{
  "name": "starlight",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@prisma/client": "^7.8.0",
      "prisma-json-types-generator": "^5.0.0",
      "@prisma/adapter-pg": "^7.8.0",
      "@prisma/instrumentation": "^7.8.0",
      "tsdown": "^0.22.1",
      "@orpc/server": "^1.14.4",
      "@orpc/openapi": "^1.14.4",
      "@orpc/client": "^1.14.4",
      "@orpc/zod": "^1.14.4",
      "zod": "^4.4.3",
      "prisma": "^7.8.0",
      "grammy": "^1.43.0",
      "ky": "^2.0.2"
    }
  },
  "scripts": {
    "lint": "turbo lint",
    "format": "turbo format",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "prestart:server": "bun run db:generate && bun run db:deploy",
    "start:server": "turbo -F server start",
    "start:web": "turbo -F web start",
    "db:deploy": "turbo -F @starlight/utils db:deploy",
    "db:generate": "turbo -F @starlight/utils db:generate",
    "db:migrate": "turbo -F @starlight/utils db:migrate",
    "queue:classify": "turbo -F server queue:classify",
    "queue:embeddings": "turbo -F server queue:embeddings"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.22.1",
    "turbo": "^2.9.16",
    "ultracite": "7.8.0"
  },
  "packageManager": "bun@1.3.0",
  "engines": {
    "bun": ">=1.3.0"
  }
}
