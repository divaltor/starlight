# openssl rand -hex 32
API_TOKEN=

DEBUG=true

LOG_LEVEL=INFO

ENABLE_CLASSIFICATION=true
ENABLE_EMBEDDINGS=true

TORCH_DEVICE=auto
# Set ONNX_MODE=cpu to keep ONNX models on CPU for stable backend comparisons.
# ONNX_MODE=cpu

AXIOM_API_TOKEN=
AXIOM_DATASET=

# Set to true to disable serving OpenAPI schema and docs endpoints
DISABLE_OPENAPI=false
