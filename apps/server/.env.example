# @BotFather
BOT_TOKEN=

NODE_ENV=development

# Main database
DATABASE_URL=

# To encrypt cookies in storage
COOKIE_ENCRYPTION_KEY=
COOKIE_ENCRYPTION_SALT=

# To store images from scrapper process
AWS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# To build link for accessing images on webpage
BASE_CDN_URL=
BASE_FRONTEND_URL=
DEFAULT_MEDIA_PATH='media/'

# AI chat replies
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
EXA_API_KEY=
EXA_API_BASE_URL=https://api.exa.ai

# Between 0 and 1
IGNORE_USER_CHANCE=0.75

# Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development

# Langfuse MCP (opencode) — base64 of `pk-lf-...:sk-lf-...`
# Generate with: echo -n "$LANGFUSE_PUBLIC_KEY:$LANGFUSE_SECRET_KEY" | base64
LANGFUSE_MCP_BASIC_TOKEN=

# Classification service
ML_BASE_URL=
ML_API_TOKEN=

ENABLE_CLASSIFICATION=true
ENABLE_EMBEDDINGS=true

# List of Telegram IDs which would have full control of bot in any chat (like creators or supervisors)
SUPERVISOR_IDS=

# List of group/supergroup chat IDs where the bot can auto-react, reply, and handle /v-like group events
WHITELIST_CHAT_IDS=
